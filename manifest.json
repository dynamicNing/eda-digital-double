{
  "manifest_version": 3,
  "name": "E大数字分身",
  "version": "1.1.0",
  "description": "采集且慢长赢同路人中E大发布的帖子内容，仅供个人学习研究",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://qieman.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "E大数字分身"
  },
  "content_scripts": [
    {
      "matches": ["https://qieman.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
